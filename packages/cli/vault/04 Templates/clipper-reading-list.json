{
  "schemaVersion": "0.1.0",
  "name": "Reading List Item",
  "behavior": "create",
  "noteNameFormat": "Reading {{title|safe_name}}",
  "path": "01 Notes",
  "context": "{{selectorHtml:article,main,.post-content,.entry-content,#content|markdown|slice:0,4000|trim}}",
  "properties": [
    { "name": "type", "value": "reading", "type": "text" },
    { "name": "status", "value": "queued", "type": "text" },
    { "name": "source", "value": "{{url}}", "type": "text" },
    { "name": "author", "value": "{{author}}", "type": "text" },
    { "name": "priority", "value": "medium", "type": "text" },
    { "name": "tags", "value": "reading", "type": "text" },
    { "name": "created", "value": "{{date:YYYY-MM-DD}}", "type": "text" },
    { "name": "updated", "value": "{{date:YYYY-MM-DD}}", "type": "text" }
  ],
  "noteContentFormat": "## Why this is on the list\n- \n\n## Notes\n{{content}}\n\n## Completion\n- [ ] Finished"
}
