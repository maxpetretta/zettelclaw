{
  "schemaVersion": "0.1.0",
  "name": "Watch List Item",
  "behavior": "create",
  "noteNameFormat": "Watch {{title|safe_name}}",
  "path": "01 Notes",
  "context": "{{selectorHtml:article,main,body|markdown|slice:0,2500|trim}}",
  "properties": [
    { "name": "type", "value": "watch", "type": "text" },
    { "name": "status", "value": "queued", "type": "text" },
    { "name": "source", "value": "{{url}}", "type": "text" },
    { "name": "platform", "value": "video", "type": "text" },
    { "name": "length", "value": "", "type": "text" },
    { "name": "tags", "value": "watch", "type": "text" },
    { "name": "created", "value": "{{date:YYYY-MM-DD}}", "type": "text" },
    { "name": "updated", "value": "{{date:YYYY-MM-DD}}", "type": "text" }
  ],
  "noteContentFormat": "## Why this is on the list\n- \n\n## Notes\n{{content}}\n\n## Completion\n- [ ] Finished"
}
