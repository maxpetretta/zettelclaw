{
  "schemaVersion": "0.1.0",
  "name": "YouTube Watch Item",
  "behavior": "create",
  "noteNameFormat": "{{schema:author}} - {{schema:name}}",
  "path": "01 Notes",
  "noteContentFormat": "![{{schema:name}}]({{url}})\n\n## Why this is on the list\n- \n\n## Notes\n{{description}}\n\n## Completion\n- [ ] Finished",
  "properties": [
    { "name": "type", "value": "watch", "type": "text" },
    { "name": "status", "value": "queued", "type": "text" },
    { "name": "platform", "value": "youtube", "type": "text" },
    { "name": "title", "value": "{{schema:name}}", "type": "text" },
    { "name": "author", "value": "{{schema:author|wikilink}}", "type": "multitext" },
    { "name": "published", "value": "{{schema:uploadDate|date:YYYY-MM-DD}}", "type": "date" },
    { "name": "source", "value": "{{url}}", "type": "text" },
    { "name": "image", "value": "{{schema:thumbnailUrl|slice:0}}", "type": "text" },
    { "name": "tags", "value": "watch,youtube", "type": "multitext" },
    { "name": "created", "value": "{{date}}", "type": "date" },
    { "name": "updated", "value": "{{date}}", "type": "date" }
  ],
  "triggers": [
    "https://www.youtube.com/watch?v=",
    "https://youtu.be/"
  ]
}
