---
import "@fontsource/sora/400.css"
import "@fontsource/sora/700.css"
import "@fontsource/jetbrains-mono/400.css"
import "@fontsource/jetbrains-mono/600.css"
import "@/styles/global.css"

const title = "Zettelclaw | Obsidian Vault Template + Agent Skill"
const description =
  "Opinionated Obsidian vault template for human-write, agent-read knowledge work. Typed notes, web clipper capture, Bases views, and CLI setup."

const pillars = [
  {
    title: "Human Writes, Agent Reads",
    body: "The vault is your thinking. The agent searches, links, and surfaces connections — never ghostwrites.",
  },
  {
    title: "Minimal by Design",
    body: "Five folders, four frontmatter properties, two templates. Nothing you won't use.",
  },
  {
    title: "CLI Install + Verify",
    body: "Install vault files, plugin binaries, OpenClaw memory-path integration, and verify the setup programmatically.",
  },
  {
    title: "Typed Content Pipeline",
    body: "Universal clipper captures articles, tweets, and videos. Bases views replace Dataview for queues and dashboards.",
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111722" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? "https://zettelclaw.com")} />
  </head>

  <body>
    <main class="page-shell">
      <section class="hero">
        <p class="eyebrow">Obsidian Vault Template + Agent Skill</p>
        <h1>Shared memory that stays useful after the chat window closes.</h1>
        <p class="lede">
          Zettelclaw gives you an opinionated Obsidian vault for one workflow: capture what you consume, write your thinking about
          it, and let an AI agent help you navigate and connect what you've written.
        </p>

        <div class="actions">
          <a class="btn btn-solid" href="https://github.com/maxpetretta/zettelclaw">View GitHub</a>
          <a class="btn btn-ghost" href="#start">Get Started</a>
        </div>
      </section>

      <section class="panel" id="included">
        <h2>What ships in the repo</h2>
        <div class="grid">
          {
            pillars.map((item) => (
              <article class="card">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="panel">
        <h2>Included workflows</h2>
        <div class="workflow-grid">
          <article>
            <h3>Web clipper capture</h3>
            <ul>
              <li>`clipper-capture.json` routes captures to `00 Inbox/`</li>
              <li>Sets `type` by URL — `tweet`, `youtube`, or `article`</li>
              <li>Every capture starts as `status: queued`</li>
            </ul>
          </article>
          <article>
            <h3>Bases queue views</h3>
            <p>
              `inbox.base` groups captures by type for triage. Create more `.base` files for reading queues, watch lists, or any
              filtered view — no Dataview needed.
            </p>
          </article>
          <article>
            <h3>OpenClaw integration</h3>
            <p>
              The CLI patches `agents.defaults.memorySearch.extraPaths` so OpenClaw can search the vault as shared memory context.
            </p>
          </article>
        </div>
      </section>

      <section class="panel" id="start">
        <h2>Start in two commands</h2>
        <pre><code>npx zettelclaw init
npx zettelclaw verify</code></pre>
        <p class="small">Need to re-pull plugin binaries later? Run `npx zettelclaw plugins`.</p>
      </section>

      <footer class="footer">
        <span>Zettelclaw</span>
        <div>
          <a href="https://github.com/maxpetretta/zettelclaw">GitHub</a>
          <a href="https://www.npmjs.com/package/zettelclaw">npm</a>
        </div>
      </footer>
    </main>
  </body>
</html>
