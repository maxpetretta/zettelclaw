---
import "@fontsource/jetbrains-mono/400.css"
import "@fontsource/jetbrains-mono/600.css"
import {
  heroEyebrow,
  heroSubtitle,
  heroTitle,
  ogImageAlt,
  pageDescription,
  pageTitle,
  siteUrl,
} from "@/lib/site"

const title = pageTitle
const description = pageDescription
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteUrl).toString()
const ogImageUrl = new URL("/og.png", Astro.site ?? siteUrl).toString()

const features = [
  {
    label: "Vault",
    title: "Five folders. Flat.",
    body: "Every note is one search away — for you and your agent. No nested hierarchies to maintain. Links and metadata do the organizing.",
  },
  {
    label: "Types",
    title: "Typed frontmatter",
    body: "note, doc, journal, article, book, youtube, tweet, and more. The agent knows what each note is and can filter, group, and reason about your vault by type.",
  },
  {
    label: "Capture",
    title: "Clipper → Inbox → Notes",
    body: "Clip any page. The template auto-classifies by URL and queues it. Process when you're ready — keep, convert to a note, or discard. Nothing rots.",
  },
  {
    label: "Views",
    title: "Bases, not Dataview",
    body: "First-party YAML views the agent can create and edit. No fragile query language. Ships with an inbox triage view; add reading queues and watch lists as you go.",
  },
  {
    label: "Search",
    title: "QMD hybrid search",
    body: "Ask a question, get your own notes back — ranked by relevance. Keyword, semantic, and hybrid search across collections. Ripgrep fallback when QMD isn't installed.",
  },
  {
    label: "Agent",
    title: "Skill-based context",
    body: "The agent learns your vault conventions from a bundled skill — not a file you maintain. OpenClaw memory paths are wired at init so context carries across sessions.",
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#13111c" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700;9..144,900&family=Newsreader:opsz,wght@6..72,400;6..72,500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="graph-bg" aria-hidden="true">
      <svg id="graph" viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" fill="none">
        <defs>
          <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
      </svg>
    </div>

    <main>
      <nav class="nav">
        <a href="/" class="wordmark">Zettelclaw</a>
        <a href="https://github.com/maxpetretta/zettelclaw" class="nav-link">GitHub</a>
      </nav>

      <section class="hero">
        <p class="eyebrow">{heroEyebrow}</p>
        <h1>{heroTitle}</h1>
        <p class="lede">
          {heroSubtitle}
        </p>
        <div class="hero-cta">
          <button class="copy-block" data-copy="npx zettelclaw" data-label="Copy">
            <span class="prompt">$</span>
            <code>npx zettelclaw</code>
            <span class="copy-label">Copy</span>
          </button>
          <a class="btn-ghost" href="https://github.com/maxpetretta/zettelclaw">View on GitHub &rarr;</a>
        </div>
      </section>

      <section class="pain reveal">
        <div class="pain-grid">
          <div class="pain-item">
            <span class="pain-stat">400+ notes</span>
            <span class="pain-arrow">&rarr;</span>
            <span class="pain-result">0 seen by your agent</span>
          </div>
          <div class="pain-item">
            <span class="pain-stat">Weekly captures</span>
            <span class="pain-arrow">&rarr;</span>
            <span class="pain-result">Never processed</span>
          </div>
          <div class="pain-item">
            <span class="pain-stat">Every conversation</span>
            <span class="pain-arrow">&rarr;</span>
            <span class="pain-result">Starts from scratch</span>
          </div>
        </div>
      </section>

      <div class="divider" aria-hidden="true"></div>

      <section class="model reveal">
        <h2><span class="text-orange">Agent reads.</span> Human writes.</h2>
        <p class="model-lede">
          The vault is your externalized thinking. The agent is a reader, navigator, and synthesizer&thinsp;&mdash;&thinsp;never a
          ghostwriter.
        </p>
        <div class="model-grid">
          <div class="model-col model-col--orange">
            <h3><span class="dot dot--orange"></span> Agent reads</h3>
            <ul>
              <li>Searches across your vault</li>
              <li>Surfaces forgotten connections</li>
              <li>Finds contradictions across time</li>
              <li>Suggests links and tags</li>
            </ul>
          </div>
          <div class="model-col model-col--purple">
            <h3><span class="dot dot--purple"></span> You write</h3>
            <ul>
              <li>One atomic idea per note</li>
              <li>Titled as complete, declarative phrases</li>
              <li>Dense <code>[[wikilinks]]</code>, stubs encouraged</li>
              <li>Your thinking, not summaries</li>
            </ul>
          </div>
        </div>
      </section>

      <div class="divider" aria-hidden="true"></div>

      <section class="features reveal">
        <h2>Everything you need.<br /><span class="text-muted">Nothing you don't.</span></h2>
        <div class="feature-grid">
          {
            features.map((f) => (
              <article class="feature-card">
                <span class="feature-label">{f.label}</span>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <div class="divider" aria-hidden="true"></div>

      <section class="mockup reveal">
        <h2>What it looks like inside.</h2>
        <div class="ide">
          <div class="ide-chrome">
            <span class="ide-dot" style="background:#ff5f57"></span>
            <span class="ide-dot" style="background:#febc2e"></span>
            <span class="ide-dot" style="background:#28c840"></span>
            <span class="ide-title">Zettelclaw — Obsidian</span>
          </div>
          <div class="ide-body">
            <aside class="ide-sidebar">
              <div class="ide-folder ide-folder--open">
                <span class="ide-folder-icon">▾</span> 00 Inbox
                <div class="ide-children">
                  <span class="ide-file" data-file="Build A Capture Habit">Build A Capture Habit.md</span>
                  <span class="ide-file ide-file--base" data-file="inbox.base">inbox.base</span>
                </div>
              </div>
              <div class="ide-folder ide-folder--open">
                <span class="ide-folder-icon">▾</span> 01 Notes
                <div class="ide-children">
                  <span class="ide-file" data-file="Flashcards Are Retrieval Practice Not Memorization">Flashcards Are Retrieval Pra…md</span>
                  <span class="ide-file" data-file="Retrieval Practice">Retrieval Practice.md</span>
                  <span class="ide-file ide-file--active" data-file="Spaced Repetition Works Because of Retrieval">Spaced Repetition Works…md</span>
                  <span class="ide-file" data-file="Titles as APIs Make Vault Navigation Possible">Titles as APIs Make Vault…md</span>
                  <span class="ide-file" data-file="Zettelclaw Vault Principles">Zettelclaw Vault Principles.md</span>
                </div>
              </div>
              <div class="ide-folder">
                <span class="ide-folder-icon">▸</span> 02 Journal
              </div>
              <div class="ide-folder">
                <span class="ide-folder-icon">▸</span> 03 Templates
              </div>
              <div class="ide-folder">
                <span class="ide-folder-icon">▸</span> 04 Attachments
              </div>
            </aside>
            <div class="ide-panes" id="ide-panes"></div>
          </div>
        </div>
      </section>

      <div class="divider" aria-hidden="true"></div>

      <section class="start reveal" id="start">
        <h2>One command. Done.</h2>
        <div class="start-commands">
          <button class="copy-block copy-block--lg" data-copy="npx zettelclaw init" data-label="Copy">
            <span class="prompt">$</span>
            <code>npx zettelclaw init</code>
            <span class="copy-label">Copy</span>
          </button>
        </div>
        <p class="start-note">
          Want to verify your setup? <code>npx zettelclaw verify</code>
        </p>
      </section>

      <footer class="footer">
        <span class="footer-wordmark">Built with 🦞 by <a href="https://x.com/maxpetretta">Max Petretta</a></span>
        <div class="footer-links">
          <a href="https://www.npmjs.com/package/zettelclaw">npm</a>
          <a href="https://github.com/maxpetretta/zettelclaw">GitHub</a>
        </div>
      </footer>
    </main>

    <script>
      // ---- Animated graph background ----
      const NS = "http://www.w3.org/2000/svg"
      const svg = document.getElementById("graph")!

      const fills = [
        "rgba(139, 92, 246, 0.30)", // purple
        "rgba(139, 92, 246, 0.50)", // purple bright
        "rgba(167, 139, 250, 0.38)", // light purple
        "rgba(109, 40, 217, 0.40)", // deep purple
        "rgba(196, 181, 253, 0.30)", // pale purple
        "rgba(249, 115, 22, 0.45)", // orange
        "rgba(251, 146, 60, 0.40)", // light orange
        "rgba(253, 186, 116, 0.32)", // amber
        "rgba(6, 182, 212, 0.32)", // teal
        "rgba(34, 211, 238, 0.28)", // cyan
        "rgba(236, 72, 153, 0.30)", // rose
        "rgba(244, 114, 182, 0.26)", // pink
      ]

      function readFill(index: number): string {
        return fills[index] ?? fills[0] ?? "rgba(139, 92, 246, 0.30)"
      }

      function pickFill(i: number): string {
        const overrides: Record<number, number> = {
          5: 5,
          14: 1,
          8: 6,
          30: 8,
          29: 9,
          4: 10,
          27: 11,
          9: 7,
          22: 3,
          31: 10,
          17: 8,
        }
        const override = overrides[i]
        if (typeof override === "number") return readFill(override)
        const r = Math.random()
        if (r < 0.55) return readFill(Math.floor(Math.random() * 5))
        if (r < 0.72) return readFill(5 + Math.floor(Math.random() * 3))
        if (r < 0.88) return readFill(8 + Math.floor(Math.random() * 2))
        return readFill(10 + Math.floor(Math.random() * 2))
      }

      // prettier-ignore
      const seed: [number, number, number][] = [
        // Cluster A - top left
        [120,140,3.5],[175,95,2.5],[80,195,2],[200,165,3.5],[155,215,2.5],
        // Cluster B - center left
        [340,310,5],[295,275,3],[385,275,2.5],[310,355,2.5],[390,345,2],
        // Cluster C - top center
        [595,115,3],[645,85,2.5],[560,150,2],[680,135,3],
        // Cluster D - center (main)
        [720,370,7],[660,330,3.5],[785,330,3],[685,425,3],[765,420,3.5],[645,395,2.5],[805,385,2.5],
        // Cluster E - right
        [1020,195,3.5],[1070,165,2.5],[1000,240,2.5],[1080,225,2],
        // Cluster F - bottom right
        [1100,475,3],[1060,515,2.5],[1140,500,2],
        // Scattered
        [450,180,2],[500,480,2],[850,195,2],[250,470,2],[900,515,2.5],[1250,300,2],[160,400,2],
      ]

      // prettier-ignore
      const edgePairs: [number, number][] = [
        [0,1],[0,2],[0,3],[3,4],[1,3],
        [5,6],[5,7],[5,8],[6,7],
        [10,11],[10,12],[11,13],[10,13],
        [14,15],[14,16],[14,17],[14,18],[14,19],[14,20],[15,19],[16,20],[17,18],
        [21,22],[21,23],[22,24],
        [25,26],[25,27],
        [3,6],[5,15],[13,14],[20,21],[18,25],[28,10],[30,21],[29,17],
      ]

      interface GNode {
        x: number
        y: number
        baseR: number
        vx: number
        vy: number
        fill: string
        phase: number
        pulseSpeed: number
        el: SVGCircleElement
      }

      interface GEdge {
        a: number
        b: number
        el: SVGLineElement
      }

      const edgeG = document.createElementNS(NS, "g")
      edgeG.setAttribute("stroke-width", "1")
      svg.appendChild(edgeG)

      const nodeG = document.createElementNS(NS, "g")
      svg.appendChild(nodeG)

      const nodes: GNode[] = seed.map(([x, y, r], i) => {
        const el = document.createElementNS(NS, "circle")
        const fill = pickFill(i)
        el.setAttribute("cx", String(x))
        el.setAttribute("cy", String(y))
        el.setAttribute("r", String(r))
        el.setAttribute("fill", fill)
        if (r >= 5) el.setAttribute("filter", "url(#glow)")
        nodeG.appendChild(el)
        return {
          x,
          y,
          baseR: r,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          fill,
          phase: Math.random() * Math.PI * 2,
          pulseSpeed: 0.4 + Math.random() * 0.6,
          el,
        }
      })

      const edges: GEdge[] = edgePairs.map(([a, b]) => {
        const el = document.createElementNS(NS, "line")
        el.setAttribute("stroke", "rgba(167, 139, 250, 0.25)")
        edgeG.appendChild(el)
        return { a, b, el }
      })

      function animate(t: number) {
        const s = t / 1000
        for (const n of nodes) {
          // Soft boundary repulsion
          if (n.x < 30) n.vx += 0.008
          if (n.x > 1410) n.vx -= 0.008
          if (n.y < 30) n.vy += 0.008
          if (n.y > 670) n.vy -= 0.008

          // Gentle drag to keep speeds bounded
          n.vx *= 0.9995
          n.vy *= 0.9995

          n.x += n.vx
          n.y += n.vy

          const r = n.baseR + Math.sin(s * n.pulseSpeed + n.phase) * n.baseR * 0.18
          n.el.setAttribute("cx", String(n.x))
          n.el.setAttribute("cy", String(n.y))
          n.el.setAttribute("r", String(r))
        }

        for (const e of edges) {
          const na = nodes[e.a]
          const nb = nodes[e.b]
          if (!(na && nb)) continue
          e.el.setAttribute("x1", String(na.x))
          e.el.setAttribute("y1", String(na.y))
          e.el.setAttribute("x2", String(nb.x))
          e.el.setAttribute("y2", String(nb.y))

          // Fade edges by distance
          const dx = na.x - nb.x
          const dy = na.y - nb.y
          const dist = Math.sqrt(dx * dx + dy * dy)
          const opacity = Math.max(0.06, 0.28 - dist / 2200)
          e.el.setAttribute("stroke-opacity", String(opacity))
        }

        requestAnimationFrame(animate)
      }

      requestAnimationFrame(animate)

      // ---- Interactive IDE mockup ----
      const panesContainer = document.getElementById("ide-panes")!
      const MAX_PANES = 4

      type VaultNote = {
        fm: Record<string, string | string[]>
        body: string[]
      }

      const vault: Record<string, VaultNote> = {
        "Spaced Repetition Works Because of Retrieval": {
          fm: { type: "note", tags: ["learning", "memory", "spaced-repetition"], created: "2026-03-04" },
          body: [
            "The spacing effect is real, but the mechanism isn't about time gaps — it's about [[Retrieval Practice]]. Every recall attempt strengthens the memory trace more than passive review.",
            "This explains why [[Flashcards Are Retrieval Practice Not Memorization]] — the act of generating the answer is what matters, not seeing it again.",
            "Bjork's [[Desirable Difficulties]] framework predicts this: harder retrieval = deeper encoding. Spacing makes retrieval harder, which is the point.",
          ],
        },
        "Retrieval Practice": {
          fm: { type: "note", tags: ["learning", "memory", "cognitive-science"], created: "2026-03-02" },
          body: [
            "Retrieval practice is the act of pulling information from memory rather than passively reviewing it. It is the single most effective learning strategy supported by cognitive science.",
            "The key insight: the act of retrieval itself strengthens the memory. This is why [[Spaced Repetition Works Because of Retrieval]] — spacing forces harder retrieval, which deepens encoding.",
            "Testing yourself isn't assessment — it's learning. See [[Flashcards Are Retrieval Practice Not Memorization]].",
          ],
        },
        "Flashcards Are Retrieval Practice Not Memorization": {
          fm: { type: "note", tags: ["learning", "tools"], created: "2026-03-03" },
          body: [
            "Flashcards work not because they help you memorize, but because each review is a [[Retrieval Practice]] event. The effort of generating the answer from memory — not recognizing it — is what strengthens the trace.",
            "This is why poorly designed flashcards (ones that test recognition instead of recall) don't work. The question must force generation.",
            "[[Spaced Repetition Works Because of Retrieval]] because it multiplies the number of effortful retrieval events over time.",
          ],
        },
        "Titles as APIs Make Vault Navigation Possible": {
          fm: { type: "note", tags: ["zettelclaw", "systems", "knowledge"], created: "2026-03-01" },
          body: [
            'A note\'s title is its interface. If you can\'t understand the note from its title alone, the title is wrong. "Spaced Repetition" is a topic label. "[[Spaced Repetition Works Because of Retrieval]]" is a claim you can link, reference, and reason about without opening the note.',
            "This principle makes the vault navigable for agents — they can reason at the title level, traversing wikilinks to build context without reading every note body.",
            "See [[Zettelclaw Vault Principles]] for the full set of conventions.",
          ],
        },
        "Zettelclaw Vault Principles": {
          fm: { type: "note", tags: ["zettelclaw", "systems", "knowledge"], created: "2026-03-01" },
          body: [
            "Zettelclaw gives you an opinionated Obsidian setup where agent and human context stay in one place.",
            "Core loop: capture quickly in 00 Inbox/, process inbox items (keep, write a note, or discard), write durable ideas as type: note in 01 Notes/, and link concepts aggressively with wikilinks.",
            "[[Titles as APIs Make Vault Navigation Possible]] — each note title should be a complete, declarative phrase that can be understood without reading the body.",
          ],
        },
        "Build A Capture Habit": {
          fm: { type: "article", status: "queued", tags: ["workflow", "learning"], source: "https://obsidian.md", created: "2026-03-05" },
          body: [
            "Start small: save interesting links with the universal capture clipper template. Process inbox items regularly.",
            "Write a durable type: note when a source triggers original thinking. Not everything you clip deserves a note — the URL still exists on the internet if you ever want it again.",
          ],
        },
      }

      const baseContent = `filters:
  and:
    - file.inFolder("00 Inbox")
    - 'file.ext == "md"'

views:
  - type: table
    name: "Inbox"
    groupBy:
      property: note.type
      direction: ASC
    order:
      - file.name
      - type
      - status
      - author
      - source
      - created`

      function fmHtml(fm: Record<string, string | string[]>): string {
        return Object.entries(fm)
          .map(([k, v]) => {
            if (Array.isArray(v))
              return `<div class="ide-fm-row"><span class="ide-fm-key">${k}:</span> <span class="ide-fm-bracket">[</span>${v.join(", ")}<span class="ide-fm-bracket">]</span></div>`
            return `<div class="ide-fm-row"><span class="ide-fm-key">${k}:</span> ${v}</div>`
          })
          .join("")
      }

      function linkify(text: string): string {
        return text.replace(/\[\[(.+?)\]\]/g, (_, title) => {
          const exists = title in vault
          const cls = exists ? "ide-link" : "ide-link ide-link--stub"
          return `<a class="${cls}" data-link="${title}">[[${title}]]</a>`
        })
      }

      function renderContent(title: string): string {
        if (title === "inbox.base") {
          return `<pre class="ide-yaml">${baseContent}</pre>`
        }
        const file = vault[title]
        if (file) {
          const body = file.body.map((p) => `<p class="ide-p">${linkify(p)}</p>`).join("")
          return `<div class="ide-fm"><span class="ide-fm-fence">---</span>${fmHtml(file.fm)}<span class="ide-fm-fence">---</span></div><h1 class="ide-h1">${title}</h1>${body}`
        }
        return `<h1 class="ide-h1">${title}</h1><p class="ide-stub-msg">This note doesn't exist yet. It's been linked from other notes — a stub waiting to be written.</p>`
      }

      // Pane stack state
      const paneStack: { title: string; el: HTMLElement }[] = []

      function createPane(title: string, collapsed: boolean): HTMLElement {
        const pane = document.createElement("div")
        pane.className = collapsed ? "ide-pane ide-pane--collapsed" : "ide-pane ide-pane--active"
        pane.dataset.paneTitle = title

        // Collapsed strip
        const strip = document.createElement("div")
        strip.className = "ide-pane-strip"
        strip.textContent = title
        strip.addEventListener("click", () => expandPane(title))
        pane.appendChild(strip)

        // Content area
        const content = document.createElement("div")
        content.className = "ide-pane-content"
        content.innerHTML = renderContent(title)
        pane.appendChild(content)

        return pane
      }

      function updateSidebar(title: string) {
        document.querySelectorAll(".ide-file").forEach((f) => f.classList.remove("ide-file--active"))
        const match = document.querySelector<HTMLElement>(`[data-file="${title}"]`)
        if (match) match.classList.add("ide-file--active")
      }

      function pushPane(title: string) {
        // If this title is already the active (rightmost) pane, do nothing
        const activePane = paneStack.at(-1)
        if (activePane?.title === title) return

        // Collapse current active pane
        if (activePane) {
          const current = activePane
          current.el.classList.remove("ide-pane--active")
          current.el.classList.add("ide-pane--collapsed")
        }

        // Evict oldest pane if at max
        if (paneStack.length >= MAX_PANES) {
          const oldest = paneStack.shift()!
          oldest.el.remove()
        }

        // Create and add new active pane
        const pane = createPane(title, false)
        panesContainer.appendChild(pane)
        paneStack.push({ title, el: pane })

        updateSidebar(title)
      }

      function expandPane(title: string) {
        const idx = paneStack.findIndex((p) => p.title === title)
        if (idx === -1) return

        // Remove all panes to the right
        while (paneStack.length > idx + 1) {
          const removed = paneStack.pop()!
          removed.el.remove()
        }

        // Mark this pane as active
        const pane = paneStack[idx]
        if (!pane) return
        pane.el.classList.remove("ide-pane--collapsed")
        pane.el.classList.add("ide-pane--active")

        updateSidebar(title)
      }

      // Sidebar clicks
      document.querySelectorAll<HTMLElement>(".ide-file[data-file]").forEach((el) => {
        el.addEventListener("click", () => pushPane(el.dataset.file!))
      })

      // Wikilink clicks (delegated)
      panesContainer.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement).closest("[data-link]") as HTMLElement | null
        if (link) pushPane(link.dataset.link!)
      })

      // Initial render
